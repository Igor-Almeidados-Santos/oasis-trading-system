# =============================================================================
# SECURITY & SENSITIVE DATA
# =============================================================================

# Environment files and secrets
.env
.env.*
!.env.example
.envrc
.secrets/
secrets/
vault/

# API Keys and credentials
api_keys/
credentials/
*.pem
*.key
*.crt
*.p12
*.jks
keystore.*

# Configuration files with sensitive data
config/production.yaml
config/staging.yaml
config/secrets.yaml
config/local.yaml
*_secrets.yaml
*_credentials.yaml

# Terraform state files (may contain sensitive data)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Kubernetes secrets
*-secret.yaml
*-secrets.yaml

# =============================================================================
