# ==================== .env.example ====================
# Application Environment
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=oasis_trading
POSTGRES_USER=oasis
POSTGRES_PASSWORD=oasis_secure_password
DATABASE_URL=postgresql+asyncpg://oasis:oasis_secure_password@localhost:5432/oasis_trading

# TimescaleDB
TIMESCALE_ENABLED=true
TIMESCALE_CHUNK_TIME_INTERVAL=1 day

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password
REDIS_DB=0
REDIS_URL=redis://:redis_secure_password@localhost:6379/0

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_GROUP_ID=oasis-trading-group

# Celery Configuration
CELERY_BROKER_URL=redis://:redis_secure_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secure_password@localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC

# Exchange API Keys (Use testnet for development)
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret
BINANCE_TESTNET=true

COINBASE_API_KEY=your-coinbase-api-key
COINBASE_API_SECRET=your-coinbase-api-secret
COINBASE_PASSPHRASE=your-coinbase-passphrase

KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_API_SECRET=your-kraken-api-secret

# Trading Configuration
DEFAULT_EXCHANGE=binance
MAX_POSITIONS=10
DEFAULT_POSITION_SIZE=100.0
DEFAULT_LEVERAGE=1
TRADING_ENABLED=false

# Risk Management
MAX_DRAWDOWN_PERCENT=15.0
MAX_DAILY_LOSS_PERCENT=5.0
MAX_POSITION_SIZE_PERCENT=10.0
STOP_LOSS_PERCENT=2.0
TAKE_PROFIT_PERCENT=5.0

# Machine Learning
ML_MODEL_PATH=/app/models
ML_BATCH_SIZE=32
ML_MAX_EPOCHS=100
ML_LEARNING_RATE=0.001
ML_DEVICE=cpu
ENABLE_GPU=false

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# AWS/Cloud Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=oasis-trading-data

# Notification Services
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=

# Security
ENABLE_2FA=false
SESSION_LIFETIME_HOURS=24
MAX_LOGIN_ATTEMPTS=5
PASSWORD_MIN_LENGTH=12
REQUIRE_STRONG_PASSWORD=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Feature Flags
ENABLE_BACKTESTING=true
ENABLE_PAPER_TRADING=true
ENABLE_LIVE_TRADING=false
ENABLE_ML_STRATEGIES=true
ENABLE_SOCIAL_TRADING=false

# Development Tools
PGADMIN_EMAIL=admin@oasis-trading.com
PGADMIN_PASSWORD=admin